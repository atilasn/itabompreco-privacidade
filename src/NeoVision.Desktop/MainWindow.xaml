<Window x:Class="NeoVision.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NeoVision.Desktop"
        Title="NeoVision AI"
        Height="920"
        Width="1150"
        MinHeight="560"
        MinWidth="880"
        Background="{StaticResource Brush.Rail}">

  <DockPanel LastChildFill="True">
    <Border DockPanel.Dock="Bottom"
            Padding="14,8"
            Background="#18181A"
            BorderBrush="#2D2D32"
            BorderThickness="0,1,0,0">
      <TextBlock Text="Estado: configure appsettings.json · API: INICIAR-API.cmd (9080) · Gravações: card 5 · Grelha MySQL: card 4 · Próximo: RTSP (LibVLC/FFmpeg)"
                 FontSize="11.5"
                 Foreground="#94A3B8"
                 TextAlignment="Left"
                 TextWrapping="Wrap" />
    </Border>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Border Grid.Row="0"
              Padding="0,14,20,14"
              Background="{StaticResource Brush.TitleBar}"
              BorderBrush="#3F3F46"
              BorderThickness="0,0,0,1">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="56" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0"
                     Text="NV"
                     FontSize="11"
                     FontWeight="Bold"
                     Foreground="#0EA5E9"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
          <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock Text="NeoVision AI"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#FAFAFA" />
            <TextBlock Text="Monitoramento, reconhecimento facial e automação (layout alinhado a VMS)"
                       FontSize="12"
                       Foreground="#A1A1AA"
                       Margin="0,3,0,0" />
          </StackPanel>
        </Grid>
      </Border>

      <Grid Grid.Row="1" Background="{StaticResource Brush.Surface}">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="56" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                BorderBrush="#2D2D32"
                BorderThickness="0,0,1,0"
                Background="{StaticResource Brush.Rail}">
          <StackPanel VerticalAlignment="Top" Margin="0,12,0,0" HorizontalAlignment="Center">
            <Button Style="{StaticResource NavRailButton}"
                    Content="&#xE80F;"
                    ToolTip="Início — painel e atalhos"
                    IsTabStop="False" />
            <Button Style="{StaticResource NavRailButton}"
                    Content="&#xE714;"
                    ToolTip="Câmeras / ao vivo"
                    IsTabStop="False" />
            <Button Style="{StaticResource NavRailButton}"
                    Content="&#xE102;"
                    ToolTip="Reprodução (gravações)"
                    IsTabStop="False" />
            <Button Style="{StaticResource NavRailButton}"
                    Content="&#xE946;"
                    ToolTip="Eventos e registo"
                    IsTabStop="False" />
            <Button Style="{StaticResource NavRailButton}"
                    Content="&#xE713;"
                    ToolTip="Configuração"
                    IsTabStop="False" />
          </StackPanel>
        </Border>

        <ScrollViewer x:Name="RootScrollViewer"
                      Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="22,18,22,20"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="{StaticResource Brush.Surface}"
                      Loaded="RootScrollViewer_Loaded">
      <StackPanel MaxWidth="1080" HorizontalAlignment="Stretch">

        <Border Background="#0A0C10" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,14">
          <StackPanel>
            <TextBlock Text="Painel (atalhos)" Foreground="#F1F5F9" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,6" />
            <TextBlock Text="Modelo: cartão de categoria à esquerda e cinco módulos à direita (tema escuro e brilho suave, como a referência). Abaixo: secções técnicas."
                       Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,14" />
            <Border Background="#0C1117" CornerRadius="12" Padding="8" Margin="0,0,0,10" BorderBrush="#3B82F6" BorderThickness="1">
              <Border.Effect>
                <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="#3B82F6" Opacity="0.35" />
              </Border.Effect>
              <Grid MinHeight="100">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="200" MinWidth="200" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        x:Name="BotaoSistema"
                        Style="{StaticResource DashSistemaMainButton}"
                        Margin="0,0,10,0"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch"
                        Tag="sistema_dash"
                        Click="DashboardButton_Click">
                  <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image x:Name="DashSistemaImage"
                           MaxWidth="200"
                           MaxHeight="100"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="Sistemas"
                               Foreground="#E2E8F0"
                               FontSize="11"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               Margin="0,4,0,0" />
                    <TextBlock Text="Gerir o seu sistema"
                               Foreground="#94A3B8"
                               FontSize="10"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                  </StackPanel>
                </Button>
                <UniformGrid Grid.Column="1" Columns="5" Rows="1" VerticalAlignment="Stretch">
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#3B8EFF" Tag="sistema_dash" Click="DashboardButton_Click" Content="Dashboard" />
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#3B8EFF" Tag="sistema_config" Click="DashboardButton_Click" Content="Configurações" />
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#3B8EFF" Tag="sistema_rel" Click="DashboardButton_Click" Content="Relatórios" />
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#3B8EFF" Tag="sistema_users" Click="DashboardButton_Click" Content="Utilizadores" />
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#3B8EFF" Tag="sistema_srv" Click="DashboardButton_Click" Content="Servidores" />
                </UniformGrid>
              </Grid>
            </Border>
            <Border Background="#0C1117" CornerRadius="12" Padding="8" Margin="0,0,0,10" BorderBrush="#7C3AED" BorderThickness="1">
              <Border.Effect>
                <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="#7C3AED" Opacity="0.35" />
              </Border.Effect>
              <Grid MinHeight="100">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="200" MinWidth="200" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#0F172A" BorderBrush="#A78BFA" BorderThickness="1.5" CornerRadius="10" Padding="10,12" Margin="0,0,10,0" VerticalAlignment="Stretch">
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock FontFamily="{StaticResource FF.Mdl2}" Text="&#xE8B5;" Foreground="#C4B5FD" FontSize="30" />
                    <TextBlock Text="IA" Foreground="White" FontWeight="Bold" FontSize="11" Margin="0,6,0,0" />
                    <TextBlock Text="Inteligência artificial" Foreground="#94A3B8" FontSize="10" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
                <UniformGrid Grid.Column="1" Columns="5" Rows="1" VerticalAlignment="Stretch">
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#A78BFA" Tag="ia_face" Click="DashboardButton_Click" Content="Reconhecimento facial" />
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#A78BFA" Tag="ia_anal" Click="DashboardButton_Click" Content="Análise inteligente" />
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#A78BFA" Tag="ia_alerta" Click="DashboardButton_Click" Content="Alertas IA" />
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#A78BFA" Tag="ia_previs" Click="DashboardButton_Click" Content="Previsões" />
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#A78BFA" Tag="ia_chat" Click="DashboardButton_Click" Content="Chat IA" />
                </UniformGrid>
              </Grid>
            </Border>
            <Border Background="#0C1117" CornerRadius="12" Padding="8" Margin="0,0,0,10" BorderBrush="#10B981" BorderThickness="1">
              <Border.Effect>
                <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="#10B981" Opacity="0.3" />
              </Border.Effect>
              <Grid MinHeight="100">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="200" MinWidth="200" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#0F172A" BorderBrush="#34D399" BorderThickness="1.5" CornerRadius="10" Padding="10,12" Margin="0,0,10,0" VerticalAlignment="Stretch">
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock FontFamily="{StaticResource FF.Mdl2}" Text="&#xE713;" Foreground="#6EE7B7" FontSize="30" />
                    <TextBlock Text="AUTOMAÇÃO" Foreground="White" FontWeight="Bold" FontSize="10" Margin="0,6,0,0" />
                    <TextBlock Text="Automatizar processos" Foreground="#94A3B8" FontSize="10" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
                <UniformGrid Grid.Column="1" Columns="5" Rows="1" VerticalAlignment="Stretch">
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#34D399" Tag="auto_rot" Click="DashboardButton_Click" Content="Rotinas" />
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#34D399" Tag="auto_ac" Click="DashboardButton_Click" Content="Acionamentos" />
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#34D399" Tag="auto_port" Click="DashboardButton_Click" Content="Portões" />
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#34D399" Tag="auto_luz" Click="DashboardButton_Click" Content="Iluminação" />
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#34D399" Tag="auto_sens" Click="DashboardButton_Click" Content="Sensores" />
                </UniformGrid>
              </Grid>
            </Border>
            <Border Background="#0C1117" CornerRadius="12" Padding="8" Margin="0,0,0,10" BorderBrush="#EF4444" BorderThickness="1">
              <Border.Effect>
                <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="#EF4444" Opacity="0.3" />
              </Border.Effect>
              <Grid MinHeight="100">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="200" MinWidth="200" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#0F172A" BorderBrush="#F87171" BorderThickness="1.5" CornerRadius="10" Padding="10,12" Margin="0,0,10,0" VerticalAlignment="Stretch">
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock FontFamily="{StaticResource FF.Mdl2}" Text="&#xE714;" Foreground="#FCA5A5" FontSize="30" />
                    <TextBlock Text="CÂMERAS" Foreground="White" FontWeight="Bold" FontSize="10" Margin="0,6,0,0" />
                    <TextBlock Text="Gerir câmeras" Foreground="#94A3B8" FontSize="10" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
                <UniformGrid Grid.Column="1" Columns="5" Rows="1" VerticalAlignment="Stretch">
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#F87171" Tag="cam_live" Click="DashboardButton_Click" Content="Ao vivo" />
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#F87171" Tag="cam_grav" Click="DashboardButton_Click" Content="Gravações" />
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#F87171" Tag="cam_snap" Click="DashboardButton_Click" Content="Snapshot" />
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#F87171" Tag="cam_ip" Click="DashboardButton_Click" Content="Câmeras IP" />
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#F87171" Tag="cam_mov" Click="DashboardButton_Click" Content="Deteção de movimento" />
                </UniformGrid>
              </Grid>
            </Border>
            <Border Background="#0C1117" CornerRadius="12" Padding="8" Margin="0,0,0,10" BorderBrush="#F97316" BorderThickness="1">
              <Border.Effect>
                <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="#F97316" Opacity="0.3" />
              </Border.Effect>
              <Grid MinHeight="100">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="200" MinWidth="200" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#0F172A" BorderBrush="#FB923C" BorderThickness="1.5" CornerRadius="10" Padding="10,12" Margin="0,0,10,0" VerticalAlignment="Stretch">
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock FontFamily="{StaticResource FF.Mdl2}" Text="&#xE81C;" Foreground="#FDBA74" FontSize="30" />
                    <TextBlock Text="TEMPO REAL" Foreground="White" FontWeight="Bold" FontSize="10" Margin="0,6,0,0" />
                    <TextBlock Text="Acompanhe em tempo real" Foreground="#94A3B8" FontSize="10" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
                <UniformGrid Grid.Column="1" Columns="5" Rows="1" VerticalAlignment="Stretch">
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#FB923C" Tag="tr_mon" Click="DashboardButton_Click" Content="Monitorização" />
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#FB923C" Tag="tr_ev" Click="DashboardButton_Click" Content="Eventos" />
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#FB923C" Tag="tr_log" Click="DashboardButton_Click" Content="Registos ao vivo" />
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#FB923C" Tag="tr_status" Click="DashboardButton_Click" Content="Estado (online)" />
                  <Button Style="{StaticResource DashFeatureTile}" BorderBrush="#FB923C" Tag="tr_not" Click="DashboardButton_Click" Content="Notificações" />
                </UniformGrid>
              </Grid>
            </Border>
            <Expander Header="Imagem de referência (mock)" IsExpanded="False" Margin="0,4,0,0" BorderThickness="0" Background="Transparent" Foreground="#CBD5E1">
              <Image x:Name="ReferenceImage"
                     MaxWidth="1000"
                     MaxHeight="440"
                     Stretch="Uniform"
                     HorizontalAlignment="Left"
                     SnapsToDevicePixels="True" />
            </Expander>
          </StackPanel>
        </Border>

        <TextBlock Text="Grelha de monitorização (modelo)"
                   Foreground="#E4E4E7"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Margin="0,0,0,10" />
        <TextBlock Text="Espaço reservado para canais — como a área de vídeo do S.I.M. Next; ligue RTSP / LibVLC numa fase posterior."
                   Style="{StaticResource Caption}"
                   Foreground="#94A3B8"
                   Margin="0,0,0,12" />
        <Grid MinHeight="280" Margin="0,0,0,18">
          <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="130" />
            <RowDefinition Height="*" MinHeight="130" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Style="{StaticResource VmsCell}" Grid.Row="0" Grid.Column="0" Margin="0,0,6,6">
            <Grid>
              <TextBlock Text="Canal 1" Foreground="#71717A" FontSize="11" VerticalAlignment="Top" HorizontalAlignment="Left" />
              <TextBlock Text="—" Foreground="#52525B" FontSize="22" VerticalAlignment="Center" HorizontalAlignment="Center" />
            </Grid>
          </Border>
          <Border Style="{StaticResource VmsCell}" Grid.Row="0" Grid.Column="1" Margin="6,0,0,6">
            <Grid>
              <TextBlock Text="Canal 2" Foreground="#71717A" FontSize="11" VerticalAlignment="Top" HorizontalAlignment="Left" />
              <TextBlock Text="—" Foreground="#52525B" FontSize="22" VerticalAlignment="Center" HorizontalAlignment="Center" />
            </Grid>
          </Border>
          <Border Style="{StaticResource VmsCell}" Grid.Row="1" Grid.Column="0" Margin="0,6,6,0">
            <Grid>
              <TextBlock Text="Canal 3" Foreground="#71717A" FontSize="11" VerticalAlignment="Top" HorizontalAlignment="Left" />
              <TextBlock Text="—" Foreground="#52525B" FontSize="22" VerticalAlignment="Center" HorizontalAlignment="Center" />
            </Grid>
          </Border>
          <Border Style="{StaticResource VmsCell}" Grid.Row="1" Grid.Column="1" Margin="6,6,0,0">
            <Grid>
              <TextBlock Text="Canal 4" Foreground="#71717A" FontSize="11" VerticalAlignment="Top" HorizontalAlignment="Left" />
              <TextBlock Text="—" Foreground="#52525B" FontSize="22" VerticalAlignment="Center" HorizontalAlignment="Center" />
            </Grid>
          </Border>
        </Grid>

        <Border x:Name="CardApi" Style="{StaticResource Card}">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
              <Border Width="4" Height="20" Background="{StaticResource Brush.Accent}" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,12,0" />
              <TextBlock Text="1 · Serviço de IA" Style="{StaticResource H2}" />
            </StackPanel>
            <TextBlock Text="Endereço base do FastAPI (uvicorn) — o mesmo do INICIAR-API.cmd, normalmente 9080 se 8080 estiver ocupada."
                       Style="{StaticResource Caption}" />
            <TextBlock Text="URL base" Style="{StaticResource FieldLabel}" Margin="0,12,0,0" />
            <TextBox x:Name="AiBaseUrlBox" Style="{StaticResource InField}" Text="http://127.0.0.1:9080" ToolTip="Ex.: http://127.0.0.1:9080" />
            <Button x:Name="TestAiButton"
                    Content="Testar conexão — GET /health"
                    Style="{StaticResource BtnMain}"
                    HorizontalAlignment="Left"
                    Margin="0,12,0,0"
                    Click="TestAiButton_Click" />
            <TextBlock x:Name="AiStatusText" Style="{StaticResource StatusLine}" Margin="0,10,0,0" />
          </StackPanel>
        </Border>

        <Border x:Name="CardDb" Style="{StaticResource Card}">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
              <Border Width="4" Height="20" Background="{StaticResource Brush.Accent}" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,12,0" />
              <TextBlock Text="2 · Base de dados MySQL" Style="{StaticResource H2}" />
            </StackPanel>
            <TextBlock Text="Connection string no appsettings (utilizador, base neovision após importar db/schema.sql)."
                       Style="{StaticResource Caption}" />
            <Button x:Name="TestDbButton"
                    Content="Testar ligação — SELECT 1"
                    Style="{StaticResource BtnMain}"
                    HorizontalAlignment="Left"
                    Margin="0,12,0,0"
                    Click="TestDbButton_Click" />
            <TextBlock x:Name="DbStatusText" Style="{StaticResource StatusLine}" Margin="0,10,0,0" />
          </StackPanel>
        </Border>

        <Border x:Name="CardOnvif" Style="{StaticResource Card}">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
              <Border Width="4" Height="20" Background="{StaticResource Brush.Accent}" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,12,0" />
              <TextBlock Text="3 · Scanner ONVIF" Style="{StaticResource H2}" />
            </StackPanel>
            <TextBlock Text="WS-Discovery (~4 s), UDP 3702. PC e câmeras na mesma sub-rede; o firewall pode bloquear a descoberta."
                       Style="{StaticResource Caption}" />
            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
              <Button x:Name="ScanOnvifButton"
                      Content="Procurar câmeras"
                      Style="{StaticResource BtnMain}"
                      MinWidth="180"
                      Click="ScanOnvifButton_Click" />
              <Button x:Name="SaveOnvifToDbButton"
                      Content="Guardar na base MySQL"
                      Style="{StaticResource BtnSecondary}"
                      MinWidth="200"
                      Margin="12,0,0,0"
                      Click="SaveOnvifToDbButton_Click" />
            </StackPanel>
            <TextBlock x:Name="OnvifStatusText" Style="{StaticResource StatusLine}" Margin="0,12,0,0" />
            <TextBlock Text="Resultados" Style="{StaticResource FieldLabel}" Margin="0,4,0,0" />
            <ListBox x:Name="OnvifList"
                     Style="{StaticResource ListNeo}"
                     MinHeight="140"
                     MaxHeight="220"
                     Margin="0,0,0,0" />
          </StackPanel>
        </Border>

        <Border x:Name="CardCameras" Style="{StaticResource Card}">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
              <Border Width="4" Height="20" Background="{StaticResource Brush.Accent}" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,12,0" />
              <TextBlock Text="4 · Câmeras (MySQL)" Style="{StaticResource H2}" />
            </StackPanel>
            <TextBlock Text="Grelha a partir da tabela cameras. Depois de guardar descobertas ONVIF, use “Atualizar grelha” (ou reabra a app: não carrega sozinha)."
                       Style="{StaticResource Caption}" />
            <Button x:Name="RefreshCamerasButton"
                    Content="Atualizar grelha"
                    Style="{StaticResource BtnMain}"
                    HorizontalAlignment="Left"
                    Margin="0,12,0,0"
                    Click="RefreshCamerasButton_Click" />
            <TextBlock x:Name="CamerasStatusText" Style="{StaticResource StatusLine}" Margin="0,10,0,0" />
            <TextBlock Text="Câmeras" Style="{StaticResource FieldLabel}" Margin="0,4,0,0" />
            <ItemsControl x:Name="CamerasItems" Margin="0,0,0,0" MinHeight="64">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type local:CameraGridItem}">
                  <Border Width="288"
                          MinHeight="88"
                          Background="{StaticResource Brush.InputBg}"
                          BorderBrush="{StaticResource Brush.Border}"
                          BorderThickness="1"
                          CornerRadius="8"
                          Padding="14,12"
                          Margin="0,0,12,12">
                    <StackPanel>
                      <TextBlock Text="{Binding Name}"
                                 Foreground="{StaticResource Brush.Accent}"
                                 FontSize="14.5"
                                 FontWeight="SemiBold"
                                 TextWrapping="Wrap" />
                      <TextBlock Text="{Binding Details}"
                                 Style="{StaticResource Caption}"
                                 Margin="0,8,0,0"
                                 TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border x:Name="CardGravacoes" Style="{StaticResource Card}">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
              <Border Width="4" Height="20" Background="{StaticResource Brush.Accent}" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,12,0" />
              <TextBlock Text="5 · Gravações (pasta de dados)" Style="{StaticResource H2}" />
            </StackPanel>
            <TextBlock Text="Após instalar, a app cria esta pasta no primeiro arranque. Pode listar ficheiros por data e nome, e abrir no leitor padrão (vídeo ou outro). Opcional: Storage:RecordingsPath no appsettings."
                       Style="{StaticResource Caption}" />
            <TextBlock Text="Caminho atual" Style="{StaticResource FieldLabel}" Margin="0,12,0,0" />
            <TextBox x:Name="RecordingsPathText"
                     Style="{StaticResource InField}"
                     IsReadOnly="True"
                     TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
              <Button x:Name="OpenRecordingsFolderButton"
                      Content="Abrir pasta no Explorador"
                      Style="{StaticResource BtnMain}"
                      Click="OpenRecordingsFolderButton_Click" />
              <Button x:Name="RefreshRecordingsListButton"
                      Content="Atualizar lista de ficheiros"
                      Style="{StaticResource BtnSecondary}"
                      MinWidth="200"
                      Margin="12,0,0,0"
                      Click="RefreshRecordingsListButton_Click" />
            </StackPanel>
            <TextBlock Text="Filtrar (opcional)" Style="{StaticResource FieldLabel}" Margin="0,14,0,0" />
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
              <TextBlock Text="Data de" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,8,0" />
              <DatePicker x:Name="RecordingsFilterFrom" Width="130" />
              <TextBlock Text="até" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="10,0,8,0" />
              <DatePicker x:Name="RecordingsFilterTo" Width="130" />
              <TextBlock Text="nome contém" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="16,0,8,0" />
              <TextBox x:Name="RecordingsFilterName" MinWidth="160" MaxWidth="280" Style="{StaticResource InField}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
              <Button Content="Aplicar filtros"
                      Style="{StaticResource BtnMain}"
                      Click="RecordingsFilterApplyButton_Click" />
              <Button Content="Limpar filtros"
                      Style="{StaticResource BtnSecondary}"
                      Margin="8,0,0,0"
                      Click="RecordingsFilterClearButton_Click" />
            </StackPanel>
            <TextBlock x:Name="RecordingsCountText" Style="{StaticResource StatusLine}" Margin="0,8,0,0" />
            <ListView x:Name="RecordingsListView"
                      MinHeight="180"
                      MaxHeight="320"
                      Margin="0,4,0,0"
                      FontSize="13"
                      Background="{StaticResource Brush.InputBg}"
                      Foreground="{StaticResource Brush.Text}"
                      BorderBrush="{StaticResource Brush.Border}"
                      MouseDoubleClick="RecordingsListView_MouseDoubleClick">
              <ListView.View>
                <GridView>
                  <GridViewColumn Header="Data / hora" DisplayMemberBinding="{Binding DateDisplay}" Width="150" />
                  <GridViewColumn Header="Ficheiro" DisplayMemberBinding="{Binding FileName}" Width="400" />
                  <GridViewColumn Header="Tamanho" DisplayMemberBinding="{Binding SizeDisplay}" Width="90" />
                </GridView>
              </ListView.View>
            </ListView>
            <Button x:Name="OpenRecordingFileButton"
                    Content="Abrir ficheiro selecionado (reproduzir com o app padrão)"
                    Style="{StaticResource BtnMain}"
                    HorizontalAlignment="Left"
                    Margin="0,10,0,0"
                    Click="OpenRecordingFileButton_Click" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
      </Grid>
    </Grid>
  </DockPanel>
</Window>
